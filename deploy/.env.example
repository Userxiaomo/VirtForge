# Copy this file to .env on the Linux VPS that runs the control plane:
#   cp .env.example .env
#
# Then edit .env and start the stack with:
#   docker compose up -d --build

# Public DNS name served by Caddy. The domain must point to this VPS.
DOMAIN=panel.example.com

# Public HTTPS URLs used by operators and agents.
MASTER_PUBLIC_BASE_URL=https://panel.example.com
MASTER_INSTALLER_BASE_URL=https://panel.example.com

# Database password used only inside the Compose stack.
POSTGRES_PASSWORD=replace-with-long-random-postgres-password

# Browser login username.
MASTER_ADMIN_USERNAME=admin

# Argon2 PHC hash of the admin token.
# Keep the value single-quoted because PHC hashes contain literal '$' characters.
# Generate it with:
#   ADMIN_TOKEN="$(openssl rand -hex 32)"
#   echo "Admin token: ${ADMIN_TOKEN}"
#   SECRET_TO_HASH="${ADMIN_TOKEN}" docker compose run --rm --no-deps --build --entrypoint /usr/local/bin/hash-secret master
MASTER_ADMIN_TOKEN_HASH='replace-with-argon2-phc-hash'

# Optional settings.
# POSTGRES_HOST_PORT=5432
# MASTER_READONLY_TOKEN_HASH=''
# MASTER_FETCH_TIMEOUT_MS=30000
# MASTER_AGENT_BINARY_PATH=
# MASTER_INSTALLER_CA_CERT_PATH=
# MASTER_INSTALLER_CLIENT_IDENTITY_PATH=
# MASTER_IMAGE=vps-master:local
# FRONTEND_IMAGE=vps-frontend:local
